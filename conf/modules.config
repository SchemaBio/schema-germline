/*
 * 模块配置 - 定义每个模块的容器、资源和发布规则
 * 
 * 资源配置优先级: 命令行参数 > modules.config > 标签默认值
 * 所有资源都会被 check_max() 限制在 params.max_* 范围内
 */
process {
    // =========================================================================
    // 全局默认容器
    // =========================================================================
    container = 'ghcr.io/pzweuj/mapping:2025dec'

    // =========================================================================
    // FASTP - 质控过滤
    // 特点: 多线程有效，内存需求低
    // =========================================================================
    withName: 'FASTP' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/fastp" },
                mode: 'copy',
                pattern: '*.{json,html}'
            ],
            [
                path: { "${params.outdir}/fastp" },
                mode: 'copy',
                pattern: '*.fq.gz',
                enabled: params.save_trimmed_reads ?: false
            ]
        ]
    }

    // =========================================================================
    // BWA_MEM2 - 比对
    // 特点: CPU 密集，内存需求高 (bwa-mem2 需要 ~64GB，bwa 需要 ~8GB)
    // 模块内会根据实际分配的内存自动选择 bwa-mem2 或 bwa
    // =========================================================================
    withName: 'BWA_MEM2' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 16, 'cpus' ) }
        memory    = { check_max( 64.GB * task.attempt, 'memory' ) }
        time      = { check_max( 24.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/alignment" },
            mode: 'copy',
            pattern: '*.{cram,bam,crai,bai}'
        ]
    }

    // =========================================================================
    // GATK 模块
    // =========================================================================
    withName: 'GATK_CREATESEQUENCEDICTIONARY' {
        container = 'broadinstitute/gatk:4.6.2.0'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/reference" },
            mode: 'copy',
            pattern: '*.dict'
        ]
    }

    withName: 'GATK_MARKDUPLICATES' {
        container = 'broadinstitute/gatk:4.6.2.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 8.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/markdup" },
                mode: 'copy',
                pattern: '*.metrics.txt'
            ],
            [
                path: { "${params.outdir}/markdup" },
                mode: 'copy',
                pattern: '*.{cram,bam,crai,bai}',
                enabled: params.save_markdup_bam ?: false
            ]
        ]
    }

    withName: 'GATK_COLLECTQCMETRICS' {
        container = 'broadinstitute/gatk:4.6.2.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/qc/gatk_metrics" },
            mode: 'copy',
            pattern: '*.metrics*'
        ]
    }

    withName: 'GATK_LEFTALIGNANDTRIMVARIANTS' {
        container = 'broadinstitute/gatk:4.6.2.0'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/variants" },
            mode: 'copy',
            pattern: '*.normalized.vcf.gz*'
        ]
    }

    withName: 'GATK_MUTECT2_MT' {
        container = 'broadinstitute/gatk:4.6.2.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/variants/mt" },
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,vcf.gz.stats}'
        ]
    }

    // =========================================================================
    // DeepVariant - 变异检测
    // 特点: GPU 可加速，CPU 模式需要较多资源
    // =========================================================================
    withName: 'DEEPVARIANT' {
        container = 'google/deepvariant:1.6.0'
        cpus      = { check_max( 16, 'cpus' ) }
        memory    = { check_max( 32.GB * task.attempt, 'memory' ) }
        time      = { check_max( 12.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/variants/deepvariant" },
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,g.vcf.gz,g.vcf.gz.tbi,html}'
        ]
    }

    // =========================================================================
    // VEP - 变异注释
    // =========================================================================
    withName: 'VEP' {
        container = 'ensemblorg/ensembl-vep:release_112.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/annotation/vep" },
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,json.gz,tsv,html}'
        ]
    }

    withName: 'VEP_DOWNLOAD_CACHE' {
        container = 'ensemblorg/ensembl-vep:release_112.0'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB, 'memory' ) }
        time      = { check_max( 4.h, 'time' ) }
    }

    // =========================================================================
    // ExpansionHunter - STR 检测
    // =========================================================================
    withName: 'EXPANSIONHUNTER' {
        container = 'clinicalgenomics/expansionhunter:5.0.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/str/expansionhunter" },
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,json}'
        ]
    }

    // =========================================================================
    // 其他 QC 模块
    // =========================================================================
    withName: 'SEX_CHECK' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/qc/sex_check" },
            mode: 'copy',
            pattern: '*.sex_check.txt'
        ]
    }

    // =========================================================================
    // BCFtools - 变异统计与 ROH 检测
    // =========================================================================
    withName: 'BCFTOOLS_ROH' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/qc/roh" },
            mode: 'copy',
            pattern: '*.roh'
        ]
    }

    withName: 'BCFTOOLS_STATS' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/qc/vcfstats" },
            mode: 'copy',
            pattern: '*.vcfstats.txt'
        ]
    }

    // =========================================================================
    // Bamdst - WES 覆盖度统计
    // =========================================================================
    withName: 'BAMDST' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/qc/bamdst" },
                mode: 'copy',
                pattern: '*.coverage.stat'
            ],
            [
                path: { "${params.outdir}/qc/bamdst" },
                mode: 'copy',
                pattern: '*.depth.stat'
            ],
            [
                path: { "${params.outdir}/qc/bamdst" },
                mode: 'copy',
                pattern: '*.chromosome.stat'
            ],
            [
                path: { "${params.outdir}/qc/bamdst" },
                mode: 'copy',
                pattern: '*.region.stat'
            ],
            [
                path: { "${params.outdir}/qc/bamdst" },
                mode: 'copy',
                pattern: '*.genelist.stat'
            ]
        ]
    }

    withName: 'BAMDST_EXTRACT_COVERAGE' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 1, 'cpus' ) }
        memory    = { check_max( 1.GB * task.attempt, 'memory' ) }
        time      = { check_max( 30.min * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/qc/bamdst" },
            mode: 'copy',
            pattern: '*.coverage.summary.txt'
        ]
    }
}
