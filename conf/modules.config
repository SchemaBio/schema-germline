        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.king*'
        ]
    }

    withName: 'PLINK2_PCA' {
        container = 'docker.biotools.space/schemabio/statistical:v2.0.0'  // Plink2, Peddy, Vcftools
