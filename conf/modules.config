    withName: 'SLIVAR_TSV' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/04_reports" },
            mode: 'copy',
            pattern: '*.slivar.tsv.gz'
        ]
    }

    withName: 'SLIVAR_DUO_DEL' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/04_reports" },
            mode: 'copy',
            pattern: '*.duo_del.tsv.gz'
        ]
    }

    // =========================================================================
    // 结果聚合脚本 - 04_reports/ 输出表
    // =========================================================================
    withName: 'AGGREGATE_QC' {
        container = 'docker.biotools.space/schemabio/base:v2.0.0'  // Python glue scripts (no bioinformatics tools)
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB, 'memory' ) }
        time      = { check_max( 30.min, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/04_reports" },
            mode: 'copy',
            pattern: '*.qc_summary.*'
        ]
    }

    withName: 'RESULTS_TO_PARQUET' {
        container = 'docker.biotools.space/schemabio/base:v2.0.0'  // Python glue scripts (no bioinformatics tools)
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB, 'memory' ) }
        time      = { check_max( 30.min, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/04_reports" },
            mode: 'copy',
            pattern: '*.parquet'
        ]
    }
