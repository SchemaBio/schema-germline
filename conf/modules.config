/*
 * 模块配置 - 定义每个模块的容器、资源和发布规则
 *
 * 输出目录结构:
 * ${params.outdir}/
 * └── {sample_id}/
 *     ├── 01_fastp/          # 质控报告
 *     ├── 02_alignment/      # 比对结果 (sorted.cram -> marked.cram)
 *     ├── 03_markdup/        # 去重统计
 *     ├── 04_coverage/       # 覆盖度统计
 *     ├── 05_sex_check/      # 性别检查
 *     ├── 06_deepvariant/    # SNP/INDEL 变异检测
 *     ├── 07_whatshap/       # 单倍型分相 (WhatsHap)
 *     ├── 08_vep/            # 变异注释
 *     ├── 08_str/            # STR 检测 (ExpansionHunter)
 *     ├── 09_str/            # STR 注释 (stranger)
 *     ├── 10_cnv/            # CNV 检测
 *     ├── 11_plink2/         # 基因型分析
 *     ├── 12_roh/            # ROH 分析
 *     ├── 13_phasing/        # Phasing 统计
 *     ├── 14_slivar/         # 变异过滤 (slivar)
 *     └── 15_svdb/           # CNV/SV 注释 (SVDB)
 *
 * 存储策略: 比对结果(sorted.cram)先保留，待MarkDuplicates完成后自动删除
 */

process {
    // =========================================================================
    // 全局默认容器
    // =========================================================================
    container = 'ghcr.io/pzweuj/mapping:2025dec'

    // =========================================================================
    // FASTP - 01_fastp/ 质控过滤
    // =========================================================================
    withName: 'FASTP' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/01_fastp" },
                mode: 'copy',
                pattern: '*.json'
            ],
            [
                path: { "${params.outdir}/${meta.id}/01_fastp" },
                mode: 'copy',
                pattern: '*.html'
            ],
            [
                path: { "${params.outdir}/${meta.id}/01_fastp" },
                mode: 'copy',
                pattern: '*.fq.gz',
                enabled: params.save_trimmed_reads ?: false
            }
        ]
    }

    // =========================================================================
    // BWA_MEM/BWA_MEM2 - 02_alignment/ 比对结果
    // =========================================================================
    withName: 'BWA_MEM' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 16, 'cpus' ) }
        memory    = { check_max( 64.GB * task.attempt, 'memory' ) }
        time      = { check_max( 24.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/02_alignment" },
            mode: 'copy',
            pattern: '*.sorted.cram'
        ]
    }

    withName: 'BWA_MEM2' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 16, 'cpus' ) }
        memory    = { check_max( 64.GB * task.attempt, 'memory' ) }
        time      = { check_max( 24.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/02_alignment" },
            mode: 'copy',
            pattern: '*.sorted.cram'
        ]
    }

    // =========================================================================
    // GATK 模块 - 03_markdup/ 去重统计
    // =========================================================================
    withName: 'GATK_MARKDUPLICATES' {
        container = 'broadinstitute/gatk:4.6.2.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 8.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/02_alignment" },
                mode: 'move',
                pattern: '*.marked.cram'
            ],
            [
                path: { "${params.outdir}/${meta.id}/02_alignment" },
                mode: 'move',
                pattern: '*.marked.cram.crai'
            ],
            [
                path: { "${params.outdir}/${meta.id}/03_markdup" },
                mode: 'copy',
                pattern: '*.metrics.txt'
            ]
        ]
        // 完成后的清理操作：删除比对产生的 sorted.cram
        afterScript = """
            # 删除 sorted.cram 节约空间（保留 marked.cram）
            rm -f ${task.workDir}/*.sorted.cram ${task.workDir}/*.sorted.cram.crai 2>/dev/null || true
        """
    }

    withName: 'GATK_CREATESEQUENCEDICTIONARY' {
        container = 'broadinstitute/gatk:4.6.2.0'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/reference" },
            mode: 'copy',
            pattern: '*.dict'
        ]
    }

    withName: 'GATK_COLLECTQCMETRICS' {
        container = 'broadinstitute/gatk:4.6.2.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_markdup" },
            mode: 'copy',
            pattern: '*.metrics*'
        ]
    }

    // =========================================================================
    // SEX_CHECK - 05_sex_check/ 性别检查
    // =========================================================================
    withName: 'SEX_CHECK' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/05_sex_check" },
            mode: 'copy',
            pattern: '*.sex_check.txt'
        ]
    }

    // =========================================================================
    // BAMDST - 04_coverage/ 覆盖度统计
    // =========================================================================
    withName: 'BAMDST' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/04_coverage" },
                mode: 'copy',
                pattern: '*.coverage.stat'
            ],
            [
                path: { "${params.outdir}/${meta.id}/04_coverage" },
                mode: 'copy',
                pattern: '*.depth.stat'
            ],
            [
                path: { "${params.outdir}/${meta.id}/04_coverage" },
                mode: 'copy',
                pattern: '*.chromosome.stat'
            ],
            [
                path: { "${params.outdir}/${meta.id}/04_coverage" },
                mode: 'copy',
                pattern: '*.region.stat'
            ],
            [
                path: { "${params.outdir}/${meta.id}/04_coverage" },
                mode: 'copy',
                pattern: '*.genelist.stat'
            ],
            [
                path: { "${params.outdir}/${meta.id}/04_coverage" },
                mode: 'copy',
                pattern: '*.distribution.stat'
            ]
        ]
    }

    withName: 'BAMDST_EXTRACT_COVERAGE' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 1, 'cpus' ) }
        memory    = { check_max( 1.GB * task.attempt, 'memory' ) }
        time      = { check_max( 30.min * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/04_coverage" },
            mode: 'copy',
            pattern: '*.coverage.summary.txt'
        ]
    }

    // =========================================================================
    // DEEPVARIANT - 06_deepvariant/ SNP/INDEL 变异检测
    // =========================================================================
    withName: 'DEEPVARIANT' {
        container = 'google/deepvariant:1.6.0'
        cpus      = { check_max( 16, 'cpus' ) }
        memory    = { check_max( 32.GB * task.attempt, 'memory' ) }
        time      = { check_max( 12.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/06_deepvariant" },
                mode: 'copy',
                pattern: '*.vcf.gz'
            ],
            [
                path: { "${params.outdir}/${meta.id}/06_deepvariant" },
                mode: 'copy',
                pattern: '*.vcf.gz.tbi'
            ],
            [
                path: { "${params.outdir}/${meta.id}/06_deepvariant" },
                mode: 'copy',
                pattern: '*.g.vcf.gz',
                enabled: params.deepvariant_gvcf ?: false
            ],
            [
                path: { "${params.outdir}/${meta.id}/06_deepvariant" },
                mode: 'copy',
                pattern: '*.visual_report.html'
            ]
        ]
    }

    // =========================================================================
    // VEP - 07_vep/ 变异注释
    // =========================================================================
    withName: 'VEP' {
        container = 'ensemblorg/ensembl-vep:release_112.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/07_vep" },
                mode: 'copy',
                pattern: '*.vep.vcf.gz'
            ],
            [
                path: { "${params.outdir}/${meta.id}/07_vep" },
                mode: 'copy',
                pattern: '*.vep.vcf.gz.tbi'
            ],
            [
                path: { "${params.outdir}/${meta.id}/07_vep" },
                mode: 'copy',
                pattern: '*.vep_summary.html'
            ]
        ]
    }

    withName: 'VEP_DOWNLOAD_CACHE' {
        container = 'ensemblorg/ensembl-vep:release_112.0'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB, 'memory' ) }
        time      = { check_max( 4.h, 'time' ) }
    }

    // =========================================================================
    // EXPANSIONHUNTER - 08_str/ STR 检测
    // =========================================================================
    withName: 'EXPANSIONHUNTER' {
        container = 'clinicalgenomics/expansionhunter:5.0.0'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/08_str" },
                mode: 'copy',
                pattern: '*.vcf.gz'
            ],
            [
                path: { "${params.outdir}/${meta.id}/08_str" },
                mode: 'copy',
                pattern: '*.vcf.gz.tbi'
            ],
            [
                path: { "${params.outdir}/${meta.id}/08_str" },
                mode: 'copy',
                pattern: '*.json'
            ]
        ]
    }

    withName: 'EXPANSIONHUNTER_DENOVO' {
        container = 'clinicalgenomics/expansionhunter:5.0.0'
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/08_str" },
            mode: 'copy',
            pattern: '*.{str_profile.json,locus.tsv,motif.tsv}'
        ]
    }

    // =========================================================================
    // STRANGER - 09_str/ STR 注释
    // =========================================================================
    withName: 'STRANGER' {
        container = 'clinicalgenomics/stranger:0.8.0'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/09_str" },
                mode: 'copy',
                pattern: '*.stranger.vcf.gz'
            ],
            [
                path: { "${params.outdir}/${meta.id}/09_str" },
                mode: 'copy',
                pattern: '*.stranger.vcf.gz.tbi'
            ]
        ]
    }

    withName: 'STRANGER_MULTISAMPLE' {
        container = 'clinicalgenomics/stranger:0.8.0'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/09_str" },
            mode: 'copy',
            pattern: '*.stranger.vcf.gz*'
        ]
    }

    // =========================================================================
    // CNVKIT - 10_cnv/ CNV 检测
    // =========================================================================
    withName: 'CNVKIT_REFERENCE' {
        container = 'ecrcnvs/cnvkit:0.9.10'
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 8.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/cnv_reference" },
            mode: 'copy',
            pattern: '*.cnn'
        ]
    }

    withName: 'CNVKIT_REFERENCE_FLAT' {
        container = 'ecrcnvs/cnvkit:0.9.10'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/cnv_reference" },
            mode: 'copy',
            pattern: '*.cnn'
        ]
    }

    withName: 'CNVKIT_CALL' {
        container = 'ecrcnvs/cnvkit:0.9.10'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/09_cnv" },
                mode: 'copy',
                pattern: '*.cnr'
            ],
            [
                path: { "${params.outdir}/${meta.id}/09_cnv" },
                mode: 'copy',
                pattern: '*.cns'
            ],
            [
                path: { "${params.outdir}/${meta.id}/09_cnv" },
                mode: 'copy',
                pattern: '*.call.cns'
            ]
        ]
    }

    withName: 'CNVKIT_EXPORT_VCF' {
        container = 'ecrcnvs/cnvkit:0.9.10'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/09_cnv" },
                mode: 'copy',
                pattern: '*.vcf.gz'
            ],
            [
                path: { "${params.outdir}/${meta.id}/09_cnv" },
                mode: 'copy',
                pattern: '*.vcf.gz.tbi'
            ]
        ]
    }

    withName: 'CNVKIT_SEX' {
        container = 'ecrcnvs/cnvkit:0.9.10'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/05_sex_check" },
            mode: 'copy',
            pattern: '*.sex_check.txt'
        ]
    }

    // =========================================================================
    // PLINK2 - 11_plink2/ 基因型分析
    // =========================================================================
    withName: 'PLINK2_VCF_TO_PLINK' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/10_plink2" },
                mode: 'copy',
                pattern: '*.pgen'
            ],
            [
                path: { "${params.outdir}/${meta.id}/10_plink2" },
                mode: 'copy',
                pattern: '*.pvar'
            ],
            [
                path: { "${params.outdir}/${meta.id}/10_plink2" },
                mode: 'copy',
                pattern: '*.psam'
            ],
            [
                path: { "${params.outdir}/${meta.id}/10_plink2" },
                mode: 'copy',
                pattern: '*.bed',
                enabled: params.plink2_output_plink1 ?: false
            ],
            [
                path: { "${params.outdir}/${meta.id}/10_plink2" },
                mode: 'copy',
                pattern: '*.bim',
                enabled: params.plink2_output_plink1 ?: false
            ],
            [
                path: { "${params.outdir}/${meta.id}/10_plink2" },
                mode: 'copy',
                pattern: '*.fam',
                enabled: params.plink2_output_plink1 ?: false
            ]
        ]
    }

    withName: 'PLINK2_QC' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/10_plink2" },
            mode: 'copy',
            pattern: '*.qc.{pgen,pvar,psam}'
        ]
    }

    withName: 'PLINK2_RELATEDNESS' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/10_plink2" },
            mode: 'copy',
            pattern: '*.king*'
        ]
    }

    withName: 'PLINK2_PCA' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/10_plink2" },
            mode: 'copy',
            pattern: '*.eigenvec'
        ]
    }

    withName: 'PLINK2_SEX_CHECK' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/10_plink2" },
            mode: 'copy',
            pattern: '*.sexcheck'
        ]
    }

    withName: 'PLINK2_SAMPLE_STATS' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/10_plink2" },
            mode: 'copy',
            pattern: '*.{smiss,het}'
        ]
    }

    withName: 'PLINK2_FREQ' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/10_plink2" },
            mode: 'copy',
            pattern: '*.afreq'
        ]
    }

    // =========================================================================
    // BCFTOOLS - 12_roh/ ROH 检测
    // =========================================================================
    withName: 'BCFTOOLS_ROH' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/12_roh" },
                mode: 'copy',
                pattern: '*.roh'
            ],
            [
                path: { "${params.outdir}/${meta.id}/12_roh" },
                mode: 'copy',
                pattern: '*.hom.vcf'
            ]
        ]
    }

    withName: 'BCFTOOLS_STATS' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/07_whatshap" },
            mode: 'copy',
            pattern: '*.vcfstats.txt'
        ]
    }

    // =========================================================================
    // WHATSHAP - 07_whatshap/ 单倍型分相
    // =========================================================================
    withName: 'WHATSHAP_PHASE' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/07_whatshap" },
                mode: 'copy',
                pattern: '*.phase.vcf.gz'
            ],
            [
                path: { "${params.outdir}/${meta.id}/07_whatshap" },
                mode: 'copy',
                pattern: '*.phase.vcf.gz.tbi'
            ]
        ]
    }

    withName: 'WHATSHAP_GENOTYPE' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/07_whatshap" },
            mode: 'copy',
            pattern: '*.genotyped.vcf.gz*'
        ]
    }

    withName: 'WHATSHAP_STATS' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/13_phasing" },
            mode: 'copy',
            pattern: '*.stats.txt'
        ]
    }

    // =========================================================================
    // SLIVAR - 14_slivar/ 变异过滤
    // =========================================================================
    withName: 'SLIVAR_EXPR' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/14_slivar" },
                mode: 'copy',
                pattern: '*.slivar.vcf.gz'
            ],
            [
                path: { "${params.outdir}/${meta.id}/14_slivar" },
                mode: 'copy',
                pattern: '*.slivar.vcf.gz.tbi'
            ]
        ]
    }

    withName: 'SLIVAR_COMPOUND_HETS' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/14_slivar" },
            mode: 'copy',
            pattern: '*.compound.vcf.gz*'
        ]
    }

    withName: 'SLIVAR_TSV' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/14_slivar" },
            mode: 'copy',
            pattern: '*.slivar.tsv.gz'
        ]
    }

    withName: 'SLIVAR_DUO_DEL' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/14_slivar" },
            mode: 'copy',
            pattern: '*.duo_del.tsv.gz'
        ]
    }

    // =========================================================================
    // SVDB - 15_svdb/ CNV/SV 注释
    // =========================================================================
    withName: 'SVDB_QUERY' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/15_svdb" },
                mode: 'copy',
                pattern: '*.svdb.vcf.gz'
            ],
            [
                path: { "${params.outdir}/${meta.id}/15_svdb" },
                mode: 'copy',
                pattern: '*.svdb.vcf.gz.tbi'
            ]
        ]
    }

    withName: 'SVDB_MERGE' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/svdb" },
            mode: 'copy',
            pattern: 'merged.vcf.gz*'
        ]
    }

    withName: 'SVDB_BUILD' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 8.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/svdb" },
            mode: 'copy',
            pattern: '*.db'
        ]
    }

    withName: 'SVDB_EXPORT' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/svdb" },
            mode: 'copy',
            pattern: '*.vcf.gz*'
        ]
    }
}
