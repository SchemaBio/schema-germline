/*
 * 定义每个步骤使用什么容器，以及发布到哪里
 */
process {
    // 1. 全局默认容器 (兜底策略)
    container = 'ghcr.io/pzweuj/mapping:2025dec'

    // 2. FASTP 质控过滤
    withName: 'FASTP' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        publishDir = [
            [
                path: { "${params.outdir}/fastp" },
                mode: 'copy',
                pattern: '*.{json,html}'
            ],
            [
                path: { "${params.outdir}/fastp" },
                mode: 'copy',
                pattern: '*.fq.gz',
                enabled: params.save_trimmed_reads ?: false  // 可选保存过滤后的 reads
            ]
        ]
    }

    // 3. BWA-MEM2 比对 (动态资源，受 max_memory 限制后自动选择 bwa/bwa-mem2)
    withName: 'BWA_MEM2' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        cpus   = { check_max( 16, 'cpus' ) }
        memory = { check_max( 64.GB, 'memory' ) }
        time   = { check_max( 24.h, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/alignment" },
            mode: 'copy',
            pattern: '*.{cram,bam,crai,bai}'
        ]
    }

    // 4. GATK 模块 - 统一使用 GATK 容器
    withName: 'GATK_CREATESEQUENCEDICTIONARY' {
        container = 'broadinstitute/gatk:4.6.2.0'
        publishDir = [
            path: { "${params.outdir}/reference" },
            mode: 'copy',
            pattern: '*.dict'
        ]
    }

    withName: 'GATK_MARKDUPLICATES' {
        container = 'broadinstitute/gatk:4.6.2.0'
        publishDir = [
            [
                path: { "${params.outdir}/markdup" },
                mode: 'copy',
                pattern: '*.metrics.txt'
            ],
            [
                path: { "${params.outdir}/markdup" },
                mode: 'copy',
                pattern: '*.{bam,bai}',
                enabled: params.save_markdup_bam ?: false  // 可选保存去重 BAM
            ]
        ]
    }

    withName: 'GATK_COLLECTQCMETRICS' {
        container = 'broadinstitute/gatk:4.6.2.0'
        publishDir = [
            path: { "${params.outdir}/qc/gatk_metrics" },
            mode: 'copy',
            pattern: '*.metrics*'
        ]
    }

    withName: 'GATK_LEFTALIGNANDTRIMVARIANTS' {
        container = 'broadinstitute/gatk:4.6.2.0'
        publishDir = [
            path: { "${params.outdir}/variants" },
            mode: 'copy',
            pattern: '*.normalized.vcf.gz*'
        ]
    }

    withName: 'GATK_MUTECT2_MT' {
        container = 'broadinstitute/gatk:4.6.2.0'
        publishDir = [
            path: { "${params.outdir}/variants/mt" },
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,vcf.gz.stats}'
        ]
    }

    // 5. DeepVariant 变异检测
    withName: 'DEEPVARIANT' {
        container = 'google/deepvariant:1.10.0-beta'
        publishDir = [
            path: { "${params.outdir}/variants/deepvariant" },
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,g.vcf.gz,g.vcf.gz.tbi,html}'
        ]
    }

    // 6. VEP 变异注释
    withName: 'VEP' {
        container = 'ensemblorg/ensembl-vep:release_115.2'
        publishDir = [
            path: { "${params.outdir}/annotation/vep" },
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,json.gz,tsv,html}'
        ]
    }

    withName: 'VEP_DOWNLOAD_CACHE' {
        container = 'ensemblorg/ensembl-vep:release_115.2'
    }

    // 7. UPD 单亲二倍体检测
    withName: 'UPD|UPD_SITES' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/upd:1.1.2'
        publishDir = [
            path: { "${params.outdir}/upd" },
            mode: 'copy',
            pattern: '*.{bed,txt}'
        ]
    }

    // 8. ExpansionHunter STR 扩展检测
    withName: 'EXPANSIONHUNTER' {
        container = 'clinicalgenomics/expansionhunter:5.0.0'
        publishDir = [
            path: { "${params.outdir}/str/expansionhunter" },
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,json}'
        ]
    }

    withName: 'EXPANSIONHUNTER_DENOVO|EXPANSIONHUNTER_DENOVO_MERGE' {
        container = 'clinicalgenomics/expansionhunter:5.0.0'
        publishDir = [
            path: { "${params.outdir}/str/expansionhunter_denovo" },
            mode: 'copy',
            pattern: '*.{json,tsv}'
        ]
    }

    // 9. 性别质控
    withName: 'SEX_CHECK' {
        container = 'ghcr.io/pzweuj/mapping:2025dec'
        publishDir = [
            path: { "${params.outdir}/qc/sex_check" },
            mode: 'copy',
            pattern: '*.sex_check.txt'
        ]
    }

    withName: 'SEX_CHECK_SUMMARY' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/samtools:1.19'
        publishDir = [
            path: { "${params.outdir}/qc/sex_check" },
            mode: 'copy',
            pattern: '*.tsv'
        ]
    }

    // 10. 样本识别
    withName: 'SAMPLE_FINGERPRINT' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/bcftools:1.19'
        publishDir = [
            path: { "${params.outdir}/qc/sample_identity" },
            mode: 'copy',
            pattern: '*.fingerprint.{vcf.gz,vcf.gz.tbi,txt}'
        ]
    }

    withName: 'SAMPLE_IDENTITY_CHECK' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/bcftools:1.19'
        publishDir = [
            path: { "${params.outdir}/qc/sample_identity" },
            mode: 'copy',
            pattern: '*.identity.txt'
        ]
    }

    withName: 'SAMPLE_IDENTITY_MATRIX' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/bcftools:1.19'
        publishDir = [
            path: { "${params.outdir}/qc/sample_identity" },
            mode: 'copy',
            pattern: '*.{tsv,txt}'
        ]
    }

    // 11. PLINK2 遗传分析
    withName: 'PLINK2_VCF_TO_PLINK' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/plink2:2.0'
        publishDir = [
            path: { "${params.outdir}/plink2" },
            mode: 'copy',
            pattern: '*.{pgen,pvar,psam,bed,bim,fam}'
        ]
    }

    withName: 'PLINK2_QC' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/plink2:2.0'
        publishDir = [
            path: { "${params.outdir}/plink2/qc" },
            mode: 'copy',
            pattern: '*.{pgen,pvar,psam,txt}'
        ]
    }

    withName: 'PLINK2_RELATEDNESS' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/plink2:2.0'
        publishDir = [
            path: { "${params.outdir}/plink2/relatedness" },
            mode: 'copy',
            pattern: '*.{king,king.id,kin0}'
        ]
    }

    withName: 'PLINK2_PCA' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/plink2:2.0'
        publishDir = [
            path: { "${params.outdir}/plink2/pca" },
            mode: 'copy',
            pattern: '*.{eigenvec,eigenval}'
        ]
    }

    withName: 'PLINK2_SEX_CHECK|PLINK2_SAMPLE_STATS|PLINK2_FREQ' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/plink2:2.0'
        publishDir = [
            path: { "${params.outdir}/plink2/stats" },
            mode: 'copy',
            pattern: '*.{sexcheck,smiss,het,afreq}'
        ]
    }

    // 12. Parquet 转换步骤
    withName: 'VCF_TO_PARQUET' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/python:3.9'
        publishDir = [
            path: { "${params.outdir}/analysis_ready" },
            mode: 'copy'
        ]
    }
}
