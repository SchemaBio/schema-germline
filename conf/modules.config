/*
 * 定义每个步骤使用什么容器，以及发布到哪里
 */
process {
    // 1. 全局默认容器 (兜底策略)
    container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/base:v1.0'

    // 2. GATK 专用容器
    withName: 'HAPLOTYPECALLER' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/gatk:4.4'
        // 发布策略：只保留 VCF，不保留中间文件
        publishDir = [
            path: { "${params.outdir}/variants" },
            mode: 'copy',
            pattern: '*.vcf.gz'
        ]
    }

    // 3. Parquet 转换步骤
    withName: 'VCF_TO_PARQUET' {
        container = 'registry.cn-hangzhou.aliyuncs.com/schemabio/python:3.9'
        // 必须发布，供前端下载
        publishDir = [
            path: { "${params.outdir}/analysis_ready" },
            mode: 'copy'
        ]
    }
}