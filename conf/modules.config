    withName: 'SVDB_BUILD' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 8.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/svdb" },
            mode: 'copy',
            pattern: '*.db'
        ]
    }

    withName: 'SVDB_EXPORT' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/svdb" },
            mode: 'copy',
            pattern: '*.vcf.gz*'
        ]
    }

    // =========================================================================
    // PLINK2 - 03_variants/snv_indel/ 基因型分析
    // =========================================================================
    withName: 'PLINK2_VCF_TO_PLINK' {
        container = 'docker.biotools.space/schemabio/statistical:v2.0.0'  // Plink2, Peddy, Vcftools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.pgen'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.pvar'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.psam'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.bed',
            enabled: params.plink2_output_plink1 ?: false
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.bim',
            enabled: params.plink2_output_plink1 ?: false
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.fam',
            enabled: params.plink2_output_plink1 ?: false
        ]
    }

    withName: 'PLINK2_QC' {
        container = 'docker.biotools.space/schemabio/statistical:v2.0.0'  // Plink2, Peddy, Vcftools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.qc.{pgen,pvar,psam}'
        ]
    }

    withName: 'PLINK2_RELATEDNESS' {
        container = 'docker.biotools.space/schemabio/statistical:v2.0.0'  // Plink2, Peddy, Vcftools
