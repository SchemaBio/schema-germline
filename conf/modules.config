    }

    withName: 'PLINK2_SAMPLE_STATS' {
        container = 'docker.biotools.space/schemabio/statistical:v2.0.0'  // Plink2, Peddy, Vcftools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.{smiss,het}'
        ]
    }

    withName: 'PLINK2_FREQ' {
        container = 'docker.biotools.space/schemabio/statistical:v2.0.0'  // Plink2, Peddy, Vcftools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.afreq'
        ]
    }

    // =========================================================================
    // BCFTOOLS - 03_variants/snv_indel/ ROH 检测 & VCF 统计
    // =========================================================================
    withName: 'BCFTOOLS_ROH' {
        container = 'docker.biotools.space/schemabio/statistical:v2.0.0'  // Plink2, Peddy, Vcftools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.roh*'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.hom.vcf*'
        ]
    }

    withName: 'BCFTOOLS_STATS' {
        container = 'docker.biotools.space/schemabio/statistical:v2.0.0'  // Plink2, Peddy, Vcftools
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.vcfstats.txt'
        ]
    }

    // =========================================================================
    // SAMPLE_FINGERPRINT - 01_qc/ 样本指纹/身份验证
    // =========================================================================
    withName: 'SAMPLE_FINGERPRINT' {
        container = 'docker.biotools.space/schemabio/mapping:2026Jan'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 30.min * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.fingerprint*'
        ]
    }

    // =========================================================================
    // SLIVAR - 03_variants/snv_indel/ 变异过滤
    // =========================================================================
    withName: 'SLIVAR_EXPR' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.slivar.vcf.gz*'
