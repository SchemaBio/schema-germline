/*
 * 模块配置 - v2.0
 *
 * Docker 镜像命名规范:
 *   docker.biotools.space/schemabio/base:latest         - Python 基础环境 (无生信工具)
 *   docker.biotools.space/schemabio/mapping:2026Jan     - 比对工具集 (samtools, bwa, fastp, mosdepth, bamdst)
 *   docker.biotools.space/schemabio/gatk:4.6.2.0         - GATK 工具集 (GATK + samtools)
 *   docker.biotools.space/schemabio/cnvkit:v0.9.11.p4    - CNV 分析工具集 (CNVkit, Stranger, SVDB, bedtools)
 *   docker.biotools.space/schemabio/expansionhunter:5.0.0 - SV 检测工具集 (ExpansionHunter, Surf, Manta)
 *   docker.biotools.space/schemabio/core:v2.0.0          - 核心分析工具集 (GenMod, Slivar, WhatsHap)
 *   docker.biotools.space/schemabio/statistical:v2.0.0   - 统计工具集 (Plink2, Peddy)
 *
 * 官方镜像 (自部署):
 *   docker.biotools.space/schemabio/deepvariant:*        - DeepVariant
 *   docker.biotools.space/schemabio/ensembl-vep:*        - VEP
 *
 * 输出目录结构:
 * ${params.outdir}/
 * └── {sample_id}/
 *     ├── 01_qc/              # 质控报告 (fastp, coverage, sex_check, metrics)
 *     ├── 02_alignment/       # 比对结果 (cram files)
 *     ├── 03_variants/        # 突变结果 (all VCF files)
 *     │   ├── snv_indel/      # SNP/INDEL
 *     │   ├── mt/             # 线粒体
 *     │   ├── str/            # STR
 *     │   └── cnv/            # CNV
 *     └── 04_reports/         # 输出表 (parquet, summary)
 *
 * 存储策略: 比对结果(sorted.cram)先保留，待MarkDuplicates完成后自动删除
 */

process {
    // =========================================================================
    // 全局默认容器
    // =========================================================================
    container = 'docker.biotools.space/schemabio/mapping:2026Jan'

    // =========================================================================
    // FASTP - 01_qc/ 质控过滤
    // =========================================================================
    withName: 'FASTP' {
        container = 'docker.biotools.space/schemabio/mapping:2026Jan'
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.json'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.html'
        ]
    }

    // =========================================================================
    // BWA_MEM/BWA_MEM2 - 02_alignment/ 比对结果
    // =========================================================================
    withName: 'BWA_MEM' {
        container = 'docker.biotools.space/schemabio/mapping:2026Jan'
        cpus      = { check_max( 16, 'cpus' ) }
        memory    = { check_max( 64.GB * task.attempt, 'memory' ) }
        time      = { check_max( 24.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/02_alignment" },
            mode: 'copy',
            pattern: '*.sorted.cram'
        ]
    }

    withName: 'BWA_MEM2' {
        container = 'docker.biotools.space/schemabio/mapping:2026Jan'
        cpus      = { check_max( 16, 'cpus' ) }
        memory    = { check_max( 64.GB * task.attempt, 'memory' ) }
        time      = { check_max( 24.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/02_alignment" },
            mode: 'copy',
            pattern: '*.sorted.cram'
        ]
    }

    // =========================================================================
    // GATK MARKDUPLICATES - 02_alignment/ 去重结果
    // =========================================================================
    withName: 'GATK_MARKDUPLICATES' {
        container = 'docker.biotools.space/schemabio/gatk:4.6.2.0'  // GATK + samtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 8.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/02_alignment" },
            mode: 'move',
            pattern: '*.marked.cram'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/02_alignment" },
            mode: 'move',
            pattern: '*.marked.cram.crai'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.metrics.txt'
        ]
    }

    // =========================================================================
    // GATK COLLECTQCMETRICS - 01_qc/ 质控指标
    // =========================================================================
    withName: 'GATK_COLLECTQCMETRICS' {
        container = 'docker.biotools.space/schemabio/gatk:4.6.2.0'  // GATK + samtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.metrics*'
        ]
    }

    // =========================================================================
    // SEX_CHECK - 01_qc/ 性别检查
    // =========================================================================
    withName: 'SEX_CHECK' {
        container = 'docker.biotools.space/schemabio/mapping:2026Jan'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.sex*.txt'
        ]
    }

    // =========================================================================
    // BAMDST - 01_qc/ 覆盖度统计
    // =========================================================================
    withName: 'BAMDST' {
        container = 'docker.biotools.space/schemabio/mapping:2026Jan'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.coverage*.txt'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.chromosome*.txt'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.region*.txt'
        ]
    }

    withName: 'BAMDST_EXTRACT_COVERAGE' {
        container = 'docker.biotools.space/schemabio/mapping:2026Jan'
        cpus      = { check_max( 1, 'cpus' ) }
        memory    = { check_max( 1.GB * task.attempt, 'memory' ) }
        time      = { check_max( 30.min * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.coverage*.txt'
        ]
    }

    // =========================================================================
    // DEEPVARIANT - 03_variants/snv_indel/ SNP/INDEL 变异检测
    // =========================================================================
    withName: 'DEEPVARIANT' {
        container = 'docker.biotools.space/schemabio/deepvariant:1.10.0'
        cpus      = { check_max( 16, 'cpus' ) }
        memory    = { check_max( 32.GB * task.attempt, 'memory' ) }
        time      = { check_max( 12.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.vcf.gz'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.vcf.gz.tbi'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.g.vcf.gz',
            enabled: params.deepvariant_gvcf ?: false
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.visual_report.html'
        ]
    }

    // =========================================================================
    // GLNEXUS - 联合分型 (多样本 gVCF 合并)
    // =========================================================================
    withName: 'GLNEXUS' {
        container = 'docker.biotools.space/schemabio/glnexus:v1.4.1'  // 官方镜像
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 32.GB * task.attempt, 'memory' ) }
        time      = { check_max( 8.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.joint.vcf.gz*'
        ]
    }

    // =========================================================================
    // GATK MUTECT2 MT - 03_variants/mt/ 线粒体变异检测
    // =========================================================================
    withName: 'GATK_MUTECT2_MT' {
        container = 'docker.biotools.space/schemabio/gatk:4.6.2.0'  // GATK + samtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/mt" },
            mode: 'copy',
            pattern: '*.vcf.gz'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/mt" },
            mode: 'copy',
            pattern: '*.vcf.gz.tbi'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/mt" },
            mode: 'copy',
            pattern: '*.vcf.gz.stats'
        ]
    }

    // =========================================================================
    // WHATSHAP - 03_variants/snv_indel/ 单倍型分相
    // =========================================================================
    withName: 'WHATSHAP_PHASE' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.phase.vcf.gz'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.phase.vcf.gz.tbi'
        ]
    }

    withName: 'WHATSHAP_GENOTYPE' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.genotyped.vcf.gz*'
        ]
    }

    withName: 'WHATSHAP_STATS' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.stats.txt'
        ]
    }

    // =========================================================================
    // VEP - 03_variants/snv_indel/ 变异注释
    // =========================================================================
    withName: 'VEP' {
        container = 'docker.biotools.space/schemabio/ensembl-vep:release_115.2'
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.vep.vcf.gz'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.vep.vcf.gz.tbi'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.vep_summary.html'
        ]
    }

    withName: 'VEP_DOWNLOAD_CACHE' {
        container = 'docker.biotools.space/schemabio/ensembl-vep:release_115.2'
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB, 'memory' ) }
        time      = { check_max( 4.h, 'time' ) }
    }

    // =========================================================================
    // GENMOD - 03_variants/snv_indel/ 遗传模式注释
    // =========================================================================
    withName: 'GENMOD_MODELS' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.genmod*.vcf.gz*'
        ]
    }

    withName: 'GENMOD_ANNOTATE' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.genmod*.vcf.gz*'
        ]
    }

    withName: 'GENMOD_SORT' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/snv_indel" },
            mode: 'copy',
            pattern: '*.genmod*.vcf.gz*'
        ]
    }

    // =========================================================================
    // GENMOD_MODELS_MT - 03_variants/mt/ 线粒体遗传模式注释
    // =========================================================================
    withName: 'GENMOD_MODELS_MT' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/mt" },
            mode: 'copy',
            pattern: '*.genmod*.vcf.gz*'
        ]
    }

    // =========================================================================
    // GENMOD_MODELS_CNV - 03_variants/cnv/ CNV遗传模式注释
    // =========================================================================
    withName: 'GENMOD_MODELS_CNV' {
        container = 'docker.biotools.space/schemabio/core:v2.0.0'  // GenMod, Slivar, WhatsHap
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/cnv" },
            mode: 'copy',
            pattern: '*.genmod*.vcf.gz*'
        ]
    }

    // =========================================================================
    // EXPANSIONHUNTER - 03_variants/str/ STR 检测
    // =========================================================================
    withName: 'EXPANSIONHUNTER' {
        container = 'docker.biotools.space/schemabio/expansionhunter:5.0.0'  // ExpansionHunter, Surf, Manta
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/str" },
            mode: 'copy',
            pattern: '*.vcf.gz'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/str" },
            mode: 'copy',
            pattern: '*.vcf.gz.tbi'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/str" },
            mode: 'copy',
            pattern: '*.json'
        ]
    }

    withName: 'EXPANSIONHUNTER_DENOVO' {
        container = 'docker.biotools.space/schemabio/expansionhunter:5.0.0'  // ExpansionHunter, Surf, Manta
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/str" },
            mode: 'copy',
            pattern: '*.{str_profile.json,locus.tsv,motif.tsv}'
        ]
    }

    // =========================================================================
    // STRANGER - 03_variants/str/ STR 注释
    // =========================================================================
    withName: 'STRANGER' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/str" },
            mode: 'copy',
            pattern: '*.stranger.vcf.gz*'
        ]
    }

    withName: 'STRANGER_MULTISAMPLE' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/str" },
            mode: 'copy',
            pattern: '*.stranger.vcf.gz*'
        ]
    }

    // =========================================================================
    // CNVKIT - 03_variants/cnv/ CNV 检测
    // =========================================================================
    withName: 'CNVKIT_TARGET' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/cnv_baseline" },
            mode: 'copy',
            pattern: 'targets.bed'
        ]
    }

    withName: 'CNVKIT_ANTITARGET' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/cnv_baseline" },
            mode: 'copy',
            pattern: 'antitargets.bed'
        ]
    }

    withName: 'CNVKIT_COVERAGE' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
    }

    withName: 'CNVKIT_REFERENCE_BUILD' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/cnv_baseline" },
            mode: 'copy',
            pattern: 'reference.cnn'
        ]
    }

    withName: 'CNVKIT_REFERENCE' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 8, 'cpus' ) }
        memory    = { check_max( 16.GB * task.attempt, 'memory' ) }
        time      = { check_max( 8.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/cnv_reference" },
            mode: 'copy',
            pattern: '*.cnn'
        ]
    }

    withName: 'CNVKIT_REFERENCE_FLAT' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/cnv_reference" },
            mode: 'copy',
            pattern: '*.cnn'
        ]
    }

    withName: 'CNVKIT_CALL' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/cnv" },
            mode: 'copy',
            pattern: '*.cnr'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/cnv" },
            mode: 'copy',
            pattern: '*.cns'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/cnv" },
            mode: 'copy',
            pattern: '*.call.cns'
        ]
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/cnv" },
            mode: 'copy',
            pattern: '*.segment*'
        ]
    }

    withName: 'CNVKIT_EXPORT_VCF' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 2, 'cpus' ) }
        memory    = { check_max( 4.GB * task.attempt, 'memory' ) }
        time      = { check_max( 1.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/cnv" },
            mode: 'copy',
            pattern: '*.vcf.gz*'
        ]
    }

    withName: 'CNVKIT_SEX' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 2.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/01_qc" },
            mode: 'copy',
            pattern: '*.sex*.txt'
        ]
    }

    // =========================================================================
    // SVDB - 03_variants/cnv/ CNV/SV 注释
    // =========================================================================
    withName: 'SVDB_QUERY' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/03_variants/cnv" },
            mode: 'copy',
            pattern: '*.svdb.vcf.gz*'
        ]
    }

    withName: 'SVDB_MERGE' {
        container = 'docker.biotools.space/schemabio/cnvkit:v0.9.11.p4'  // CNVkit, Stranger, SVDB, bedtools
        cpus      = { check_max( 4, 'cpus' ) }
        memory    = { check_max( 8.GB * task.attempt, 'memory' ) }
        time      = { check_max( 4.h * task.attempt, 'time' ) }
        publishDir = [
            path: { "${params.outdir}/svdb" },
            mode: 'copy',
            pattern: 'merged.vcf.gz*'
        ]
