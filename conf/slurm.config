// SLURM HPC 集群配置
// 用户可根据实际集群环境修改以下参数

process {
    executor       = 'slurm'
    queue          = 'normal'              // SLURM 队列名称
    clusterOptions = '--account=default'   // SLURM 提交选项 (如 --account=your_account)
}

executor {
    queueSize       = 100                   // 最大排队任务数
    submitRateLimit = '10 sec'              // 提交速率限制
    pollInterval    = '30 sec'              // 状态检查间隔
}

params {
    max_cpus   = 32                         // 最大 CPU 数
    max_memory = '128.GB'                   // 最大内存
    max_time   = '168.h'                    // 最大运行时间
}