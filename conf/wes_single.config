/*
 * WES_SINGLE 完整流程配置
 *
 * 包含：质控、比对、变异检测、注释、CNV、STR、线粒体等
 *
 * 使用方式:
 *   nextflow run main.nf -entry WES_SINGLE --config examples/sample.json
 *
 * 配置文件加载顺序:
 *   1. nextflow.config (公共配置)
 *   2. conf/wes_single.config (本文件)
 *   3. --config sample.json (用户配置)
 */

// ============================================================================
// WES_SINGLE 专用参数
// ============================================================================
params {

    // DeepVariant 参数
    deepvariant_gvcf = false

    // Plink2 参数
    plink2_output_plink1 = false
    plink2_maf = 0.01
    plink2_geno = 0.05
    plink2_mind = 0.05
    plink2_hwe = 1e-6
    plink2_pca_components = 10

    // 样本鉴定参数
    identity_concordance_threshold = 0.95

    // 性别检查参数
    sex_check_threshold = 10

    // VEP 参数
    vep_pick = true
    vep_refseq_only = false
    vep_cache_dir = null

    // CNVkit 参数
    cnvkit_target_avg_size = 267
    cnvkit_antitarget_avg_size = 100000
}