/*
 * 云端基础设施配置 - 阿里云
 */

// 阿里云 K8s 配置
process.executor = 'k8s'

docker.enabled = true

// K8s 集群配置
k8s {
    namespace        = 'nextflow'
    serviceAccount   = 'nextflow-sa'
    storageClaimName = 'nextflow-pvc'
    storageMountPath = '/workspace'
    
    // 镜像拉取策略
    pullPolicy       = 'IfNotPresent'
}

// 自动重试策略：Spot 实例被抢占 (exit 137) 或 OOM 时重试
process.errorStrategy = { task.exitStatus in [137, 143, 104] ? 'retry' : 'finish' }
process.maxRetries    = 3

// 资源标签 (用于财务核算和资源追踪)
process.pod = [
    [label: 'project', value: 'schema-germline'],
    [label: 'cost-center', value: 'production'],
    [label: 'environment', value: 'prod']
]

// 节点选择器 (可选 - 指定运行在特定节点池)
// process.pod = [[nodeSelector: 'node-type', value: 'compute']]

// 资源请求和限制
process {
    // 计算密集型任务
    withLabel: 'process_high' {
        cpus   = 16
        memory = '64.GB'
        pod    = [[request: 'cpu', value: '16'], [request: 'memory', value: '64Gi']]
    }
    
    // 中等资源任务
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '32.GB'
        pod    = [[request: 'cpu', value: '8'], [request: 'memory', value: '32Gi']]
    }
    
    // 轻量任务
    withLabel: 'process_low' {
        cpus   = 2
        memory = '8.GB'
        pod    = [[request: 'cpu', value: '2'], [request: 'memory', value: '8Gi']]
    }
}