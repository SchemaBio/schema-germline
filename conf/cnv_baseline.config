/*
 * CNV_BASELINE 流程配置 (CNV 参考基线构建)
 *
 * 包含：CNVkit target/antitarget 生成 + reference 构建
 *
 * 使用方式:
 *   nextflow run main.nf -entry CNV_BASELINE --config examples/cnv_baseline.json
 *
 * 配置文件加载顺序:
 *   1. nextflow.config (公共配置)
 *   2. conf/cnv_baseline.config (本文件)
 *   3. --config sample.json (用户配置)
 */

// ============================================================================
// CNV_BASELINE 专用参数
// ============================================================================
params {

    // CNVkit 参数
    cnvkit_target_avg_size = 267
    cnvkit_antitarget_avg_size = 100000
}