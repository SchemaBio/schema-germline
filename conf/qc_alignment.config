/*
 * QC_ALIGNMENT 流程配置 (质控 + 比对)
 *
 * 包含：FASTP 质控 + BWA 比对
 *
 * 使用方式:
 *   nextflow run main.nf -entry QC_ALIGNMENT --config examples/qc_alignment.json
 *
 * 配置文件加载顺序:
 *   1. nextflow.config (公共配置)
 *   2. conf/qc_alignment.config (本文件)
 *   3. --config sample.json (用户配置)
 */

// ============================================================================
// QC_ALIGNMENT 专用参数
// ============================================================================
params {

    // 质控输出控制
    save_trimmed_reads = false

    // XAMDST 参数 (覆盖度统计)
    xamdst_cutoffdepth = 10
}