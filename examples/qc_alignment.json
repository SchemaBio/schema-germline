/*
 * QC_ALIGNMENT 流程配置文件 (质控 + 比对)
 *
 * 使用方式:
 *   nextflow run main.nf -profile docker -entry QC_ALIGNMENT --config examples/qc_alignment.json
 *
 * 最小配置只需要:
 *   - sample_id
 *   - read1, read2
 *   - reference.fasta
 *   - outdir
 */

{
  "sample_id": "sample001",
  "read1": "/data/fastq/sample001_R1.fastq.gz",
  "read2": "/data/fastq/sample001_R2.fastq.gz",
  "reference": {
    "fasta": "/reference/hg38.fa"
  },
  "outdir": "/results/sample001_qc_alignment"
}