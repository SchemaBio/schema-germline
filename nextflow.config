/*
 * Schema Germline Pipeline - Nextflow Configuration
 *
 * 环境与容器强制绑定：
 *   - 本地 (local)      → Podman (rootless, 无需 sudo)
 *   - HPC (SLURM/LSF)   → Singularity (无 Docker daemon)
 *   - 云端 (K8s/阿里云/腾讯云) → Docker (云端有 Docker daemon)
 */

// ============================================================================
// 全局参数
// ============================================================================
params {
    // 输入输出
    input                = null
    outdir               = './results'

    // 参考基因组
    genome               = null
    fasta                = null
    fasta_fai            = null

    // 可选输出控制
    save_trimmed_reads   = false
    save_markdup_bam     = false

    // CNVkit 参数
    cnvkit_target_avg_size      = 267       // target 区域平均大小
    cnvkit_antitarget_avg_size  = 100000    // antitarget 区域平均大小

    // 资源限制 (可被 profile 或命令行覆盖)
    max_cpus             = 16
    max_memory           = '64.GB'
    max_time             = '240.h'
}

// ============================================================================
// 默认进程配置
// ============================================================================
process {
    // 默认资源
    cpus   = { check_max( 2, 'cpus' ) }
    memory = { check_max( 4.GB, 'memory' ) }
    time   = { check_max( 4.h, 'time' ) }
    
    // 默认错误处理 (支持重试时资源翻倍)
    errorStrategy = { task.exitStatus in [143,137,104,134,139,140] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'
    
    // =========================================================================
    // CPU 标签 (独立控制线程数)
    // =========================================================================
    withLabel: 'cpu_low' {
        cpus = { check_max( 2 * task.attempt, 'cpus' ) }
    }
    withLabel: 'cpu_medium' {
        cpus = { check_max( 8 * task.attempt, 'cpus' ) }
    }
    withLabel: 'cpu_high' {
        cpus = { check_max( 16 * task.attempt, 'cpus' ) }
    }
    
    // =========================================================================
    // 内存标签 (独立控制内存)
    // =========================================================================
    withLabel: 'mem_low' {
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
    }
    withLabel: 'mem_medium' {
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
    }
    withLabel: 'mem_high' {
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
    }
    
    // =========================================================================
    // 时间标签
    // =========================================================================
    withLabel: 'time_short' {
        time = { check_max( 4.h * task.attempt, 'time' ) }
    }
    withLabel: 'time_medium' {
        time = { check_max( 12.h * task.attempt, 'time' ) }
    }
    withLabel: 'time_long' {
        time = { check_max( 48.h * task.attempt, 'time' ) }
    }
}

// ============================================================================
// 加载模块配置
// ============================================================================
includeConfig 'conf/modules.config'

// ============================================================================
// Profiles - 运行环境配置
// ============================================================================
profiles {

    // -------------------------------------------------------------------------
    // 本地单机运行 (资源受限) - 强制使用 Podman (rootless)
    // -------------------------------------------------------------------------
    local {
        params.max_cpus   = 4
        params.max_memory = '12.GB'
        params.max_time   = '24.h'
        process.executor  = 'local'

        // 强制使用 Podman (避免 Docker root 权限问题)
        podman {
            enabled         = true
            podman.user     = '1000:1000'  // 使用当前用户权限
            docker.enabled  = false
            singularity.enabled = false
        }
    }

    // -------------------------------------------------------------------------
    // HPC - SLURM 调度器 - 强制使用 Singularity
    // -------------------------------------------------------------------------
    slurm {
        params.max_cpus        = 32
        params.max_memory      = '128.GB'
        params.max_time        = '168.h'
        process.executor       = 'slurm'
        process.queue          = 'normal'
        process.clusterOptions = '--account=default'

        executor {
            queueSize          = 100
            submitRateLimit    = '10 sec'
            pollInterval       = '30 sec'
        }

        // 强制使用 Singularity
        singularity {
            enabled        = true
            autoMounts     = true
            cacheDir       = "${HOME}/.singularity/cache"
            pullTimeout    = '60 min'
            docker.enabled = false
            podman.enabled = false
        }
    }

    // -------------------------------------------------------------------------
    // HPC - LSF 调度器 - 强制使用 Singularity
    // -------------------------------------------------------------------------
    lsf {
        params.max_cpus        = 32
        params.max_memory      = '128.GB'
        params.max_time        = '168.h'
        process.executor       = 'lsf'
        process.queue          = 'normal'

        executor {
            queueSize          = 100
            submitRateLimit    = '10 sec'
            pollInterval       = '30 sec'
        }

        // 强制使用 Singularity
        singularity {
            enabled        = true
            autoMounts     = true
            cacheDir       = "${HOME}/.singularity/cache"
            pullTimeout    = '60 min'
            docker.enabled = false
            podman.enabled = false
        }
    }
    
    // -------------------------------------------------------------------------
    // 云端 - Kubernetes - 使用 Docker
    // -------------------------------------------------------------------------
    k8s {
        params.max_cpus        = 64
        params.max_memory      = '256.GB'
        process.executor       = 'k8s'

        k8s {
            namespace          = 'nextflow'
            serviceAccount     = 'nextflow-sa'
            storageClaimName   = 'nextflow-pvc'
            storageMountPath   = '/workspace'
        }

        process.pod = [
            [label: 'app', value: 'schema-germline']
        ]

        // 云端有 Docker daemon，使用 Docker
        docker {
            enabled         = true
            singularity.enabled = false
            podman.enabled  = false
        }
    }

    // -------------------------------------------------------------------------
    // 云端 - 阿里云 - 使用 Docker
    // -------------------------------------------------------------------------
    aliyun {
        params.max_cpus   = 64
        params.max_memory = '256.GB'
        includeConfig 'conf/aliyun.config'

        // 云端有 Docker daemon，使用 Docker
        docker {
            enabled         = true
            singularity.enabled = false
            podman.enabled  = false
        }
    }

    // -------------------------------------------------------------------------
    // 云端 - 腾讯云 - 使用 Docker
    // -------------------------------------------------------------------------
    tencent {
        params.max_cpus   = 64
        params.max_memory = '256.GB'
        includeConfig 'conf/tencent.config'

        // 云端有 Docker daemon，使用 Docker
        docker {
            enabled         = true
            singularity.enabled = false
            podman.enabled  = false
        }
    }
    
    // -------------------------------------------------------------------------
    // 测试 Profile (最小资源)
    // -------------------------------------------------------------------------
    test {
        params.max_cpus   = 2
        params.max_memory = '6.GB'
        params.max_time   = '1.h'
    }
}

// ============================================================================
// 执行报告和追踪
// ============================================================================
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/dag.svg"
}

// ============================================================================
// Manifest - 流程元信息
// ============================================================================
manifest {
    name            = 'schema-germline'
    author          = 'Schema Bio'
    description     = 'Germline variant calling pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

// ============================================================================
// 资源检查函数 - 确保不超过最大限制
// ============================================================================
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Max memory '${params.max_memory}' is not valid, using default value"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Max time '${params.max_time}' is not valid, using default value"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "WARNING: Max cpus '${params.max_cpus}' is not valid, using default value"
            return obj
        }
    }
}
