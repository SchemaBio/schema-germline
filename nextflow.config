/*
 * Schema Germline Pipeline - Nextflow Configuration
 * 支持: 本地单机 | HPC (SLURM/LSF) | 云端 (K8s)
 * 容器: Docker | Singularity | Podman
 */

// ============================================================================
// 全局参数
// ============================================================================
params {
    // 输入输出
    input                = null
    outdir               = './results'
    
    // 参考基因组
    genome               = null
    fasta                = null
    fasta_fai            = null
    
    // 可选输出控制
    save_trimmed_reads   = false
    save_markdup_bam     = false
    
    // 资源限制 (可被 profile 覆盖)
    max_cpus             = 16
    max_memory           = '128.GB'
    max_time             = '240.h'
}

// ============================================================================
// 默认进程配置
// ============================================================================
process {
    // 默认资源
    cpus   = { check_max( 2 * task.attempt, 'cpus' ) }
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h * task.attempt, 'time' ) }
    
    // 默认错误处理
    errorStrategy = { task.exitStatus in [143,137,104,134,139,140] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'
    
    // 资源标签定义
    withLabel: 'process_high' {
        cpus   = { check_max( 16 * task.attempt, 'cpus' ) }
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h * task.attempt, 'time' ) }
    }
    
    withLabel: 'process_medium' {
        cpus   = { check_max( 8 * task.attempt, 'cpus' ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h * task.attempt, 'time' ) }
    }
    
    withLabel: 'process_low' {
        cpus   = { check_max( 2 * task.attempt, 'cpus' ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }
}

// ============================================================================
// 加载模块配置
// ============================================================================
includeConfig 'conf/modules.config'

// ============================================================================
// Profiles - 运行环境配置
// ============================================================================
profiles {

    // -------------------------------------------------------------------------
    // 本地单机运行
    // -------------------------------------------------------------------------
    standard {
        process.executor = 'local'
    }
    
    docker {
        docker.enabled         = true
        singularity.enabled    = false
        podman.enabled         = false
    }
    
    // -------------------------------------------------------------------------
    // HPC - SLURM 调度器
    // -------------------------------------------------------------------------
    slurm {
        process.executor       = 'slurm'
        process.queue          = 'normal'
        process.clusterOptions = '--account=default'
        
        // SLURM 特定配置
        executor {
            queueSize          = 100
            submitRateLimit    = '10 sec'
            pollInterval       = '30 sec'
        }
    }
    
    // -------------------------------------------------------------------------
    // HPC - LSF 调度器
    // -------------------------------------------------------------------------
    lsf {
        process.executor       = 'lsf'
        process.queue          = 'normal'
        
        executor {
            queueSize          = 100
            submitRateLimit    = '10 sec'
            pollInterval       = '30 sec'
        }
    }
    
    // -------------------------------------------------------------------------
    // HPC 容器运行时 - Singularity
    // -------------------------------------------------------------------------
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "${HOME}/.singularity/cache"
        docker.enabled         = false
        podman.enabled         = false
        
        // 将 Docker 镜像转换为 Singularity 格式
        singularity.pullTimeout = '60 min'
    }
    
    // -------------------------------------------------------------------------
    // HPC 容器运行时 - Podman
    // -------------------------------------------------------------------------
    podman {
        podman.enabled         = true
        docker.enabled         = false
        singularity.enabled    = false
    }
    
    // -------------------------------------------------------------------------
    // 云端 - Kubernetes
    // -------------------------------------------------------------------------
    k8s {
        process.executor       = 'k8s'
        docker.enabled         = true
        
        // K8s 命名空间和服务账号
        k8s {
            namespace          = 'nextflow'
            serviceAccount     = 'nextflow-sa'
            storageClaimName   = 'nextflow-pvc'
            storageMountPath   = '/workspace'
        }
        
        // Pod 配置
        process.pod = [
            [label: 'app', value: 'schema-germline']
        ]
    }
    
    // -------------------------------------------------------------------------
    // 云端 - 阿里云
    // -------------------------------------------------------------------------
    aliyun {
        includeConfig 'conf/aliyun.config'
    }
    
    // -------------------------------------------------------------------------
    // 云端 - 腾讯云
    // -------------------------------------------------------------------------
    tencent {
        includeConfig 'conf/tencent.config'
    }
    
    // -------------------------------------------------------------------------
    // 测试 Profile
    // -------------------------------------------------------------------------
    test {
        params.max_cpus   = 2
        params.max_memory = '6.GB'
        params.max_time   = '6.h'
    }
}


// ============================================================================
// 执行报告和追踪
// ============================================================================
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/dag.svg"
}

// ============================================================================
// Manifest - 流程元信息
// ============================================================================
manifest {
    name            = 'schema-germline'
    author          = 'Schema Bio'
    description     = 'Germline variant calling pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

// ============================================================================
// 资源检查函数
// ============================================================================
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Max memory '${params.max_memory}' is not valid, using default value"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Max time '${params.max_time}' is not valid, using default value"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "WARNING: Max cpus '${params.max_cpus}' is not valid, using default value"
            return obj
        }
    }
}
